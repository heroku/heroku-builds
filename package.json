{
  "name": "@heroku-cli/heroku-builds",
  "version": "2.0.0",
  "description": "Heroku CLI plugin to list and create builds for Heroku apps",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-builds.git"
  },
  "engines": {
    "node": ">= 22"
  },
  "keywords": [
    "heroku-plugin"
  ],
  "author": "Heroku",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/heroku/heroku-builds/issues"
  },
  "homepage": "https://github.com/heroku/heroku-builds",
  "scripts": {
    "build": "rm -rf dist && tsc && oclif manifest && oclif readme",
    "lint": "eslint .",
    "postpublish": "rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepare": "npm run build",
    "test": "c8 mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "oclif": {
    "commands": "./dist/commands",
    "bin": "heroku",
    "devPlugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ]
  },
  "dependencies": {
    "@heroku-cli/command": "^13.0.0",
    "@heroku-cli/schema": "^1.0.25",
    "@heroku/heroku-cli-util": "^10.9.0",
    "@heroku/http-call": "^5.4.0",
    "@oclif/core": "^4.3.0",
    "ignore": "~ 5.3.1",
    "strftime": "0.10.3",
    "tar": "~7.5.4"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^5",
    "@oclif/plugin-plugins": "2.4.7",
    "@heroku-cli/test-utils": "^0.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/strftime": "^0.9.8",
    "@types/tar": "^6.1.13",
    "c8": "^10.1.3",
    "chai": "^5.1.2",
    "eslint": "^9",
    "eslint-plugin-mocha": "^11.2.0",
    "mocha": "^11",
    "nock": "^14",
    "oclif": "4.22.87",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "oclif.manifest.json",
    "/dist"
  ],
  "//overrides": "serialize-javascript: mocha transitive dep, pinned for CVE-2024-11831",
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
